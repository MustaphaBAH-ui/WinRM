<Window x:Class="ResourceMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ResourceMonitor"
        Title="Resource Monitor" Height="480" Width="860"
        Background="#1a1a2e" Foreground="White"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <local:SparklineConverter x:Key="SparkConverter"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"   Value="#16213e"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding"      Value="16"/>
            <Setter Property="Margin"       Value="8"/>
        </Style>

        <Style x:Key="BigNum" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#8888aa"/>
            <Setter Property="Margin"     Value="0,4,0,0"/>
        </Style>

        <Style x:Key="SparkLine" TargetType="Polyline">
            <Setter Property="StrokeThickness" Value="1.5"/>
            <Setter Property="Fill"            Value="Transparent"/>
            <Setter Property="Stretch"         Value="Fill"/>
            <Setter Property="Width"           Value="200"/>
            <Setter Property="Height"          Value="50"/>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- CPU -->
        <Border Style="{StaticResource Card}" Grid.Column="0">
            <StackPanel>
                <TextBlock Text="CPU" Style="{StaticResource Label}"
                           FontSize="14" Foreground="#a0a0cc"/>
                <TextBlock Style="{StaticResource BigNum}">
                    <Run Text="{Binding CpuPercent, StringFormat={}{0:F0}}"/>
                    <Run Text="%" FontSize="18" Foreground="#8888aa"/>
                </TextBlock>
                <TextBlock Text="% utilisation" Style="{StaticResource Label}"/>
                <Polyline Style="{StaticResource SparkLine}"
                          Stroke="#7c6ff7"
                          Points="{Binding CpuHistory,
                                  Converter={StaticResource SparkConverter}}"
                          Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <!-- RAM -->
        <Border Style="{StaticResource Card}" Grid.Column="1">
            <StackPanel>
                <TextBlock Text="Memory" Style="{StaticResource Label}"
                           FontSize="14" Foreground="#a0a0cc"/>
                <TextBlock Style="{StaticResource BigNum}">
                    <Run Text="{Binding RamUsedGb, StringFormat={}{0:F1}}"/>
                    <Run Text=" GB" FontSize="18" Foreground="#8888aa"/>
                </TextBlock>
                <TextBlock Style="{StaticResource Label}">
                    <Run Text="{Binding RamPercent, StringFormat={}{0:F0}}"/>
                    <Run Text="% of "/>
                    <Run Text="{Binding RamTotalGb, StringFormat={}{0:F1}}"/>
                    <Run Text=" GB"/>
                </TextBlock>
                <Polyline Style="{StaticResource SparkLine}"
                          Stroke="#3dd6ac"
                          Points="{Binding RamHistory,
                                  Converter={StaticResource SparkConverter}}"
                          Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <!-- Disk -->
        <Border Style="{StaticResource Card}" Grid.Column="2">
            <StackPanel>
                <TextBlock Text="Disk" Style="{StaticResource Label}"
                           FontSize="14" Foreground="#a0a0cc"/>
                <TextBlock Style="{StaticResource BigNum}">
                    <Run Text="{Binding DiskReadMbs, StringFormat={}{0:F1}}"/>
                    <Run Text=" MB/s" FontSize="18" Foreground="#8888aa"/>
                </TextBlock>
                <TextBlock Style="{StaticResource Label}">
                    <Run Text="Read  /  Write "/>
                    <Run Text="{Binding DiskWriteMbs, StringFormat={}{0:F1}}"/>
                    <Run Text=" MB/s"/>
                </TextBlock>
                <Polyline Style="{StaticResource SparkLine}"
                          Stroke="#f7a05a"
                          Points="{Binding DiskReadHistory,
                                  Converter={StaticResource SparkConverter}}"
                          Margin="0,12,0,0"/>
                <Polyline Style="{StaticResource SparkLine}"
                          Stroke="#f75a5a"
                          Points="{Binding DiskWriteHistory,
                                  Converter={StaticResource SparkConverter}}"
                          Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Network -->
        <Border Style="{StaticResource Card}" Grid.Column="3">
            <StackPanel>
                <TextBlock Text="Network" Style="{StaticResource Label}"
                           FontSize="14" Foreground="#a0a0cc"/>
                <TextBlock Style="{StaticResource BigNum}">
                    <Run Text="{Binding NetSentKbs, StringFormat={}{0:F0}}"/>
                    <Run Text=" KB/s" FontSize="18" Foreground="#8888aa"/>
                </TextBlock>
                <TextBlock Style="{StaticResource Label}">
                    <Run Text="Sent  /  Recv "/>
                    <Run Text="{Binding NetRecvKbs, StringFormat={}{0:F0}}"/>
                    <Run Text=" KB/s"/>
                </TextBlock>
                <Polyline Style="{StaticResource SparkLine}"
                          Stroke="#5ab4f7"
                          Points="{Binding NetSentHistory,
                                  Converter={StaticResource SparkConverter}}"
                          Margin="0,12,0,0"/>
                <Polyline Style="{StaticResource SparkLine}"
                          Stroke="#5af7a0"
                          Points="{Binding NetRecvHistory,
                                  Converter={StaticResource SparkConverter}}"
                          Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>